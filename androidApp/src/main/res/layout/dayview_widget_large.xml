<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dayview_widget_background"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="98dp"
            android:layout_height="98dp">

            <ImageView
                android:id="@+id/widget_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/widget_ring_preview_description"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/widget_remaining"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:maxLines="1"
                android:padding="18dp"
                android:text="@string/widget_preview_remaining"
                android:textColor="@color/dayview_widget_text"
                android:textSize="16sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15"
                android:text="@string/widget_name"
                android:textColor="@color/dayview_widget_mint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/widget_day_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/widget_day_remaining"
                android:textColor="@color/dayview_widget_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/widget_day_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:maxLines="1"
                android:text="@string/widget_preview_day_range"
                android:textColor="@color/dayview_widget_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/widget_goal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/widget_preview_goal"
                android:textColor="@color/dayview_widget_text"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_focus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:background="@drawable/dayview_widget_focus_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingTop="6dp"
        android:paddingRight="10dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/widget_focus_label"
            android:textColor="@color/dayview_widget_mint"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_focus_intention"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="9dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_preview_focus"
            android:textColor="@color/dayview_widget_text"
            android:textSize="13sp" />

        <Chronometer
            android:id="@+id/widget_focus_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="monospace"
            android:textColor="@color/dayview_widget_text"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
