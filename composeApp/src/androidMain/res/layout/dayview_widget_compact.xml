<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dayview_widget_background"
    android:baselineAligned="false"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <ImageView
            android:id="@+id/widget_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/widget_ring_preview_description"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/widget_remaining"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:padding="12dp"
            android:text="@string/widget_preview_remaining"
            android:textColor="@color/dayview_widget_text"
            android:textSize="11sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="9dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:text="@string/widget_name"
            android:textColor="@color/dayview_widget_mint"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_day_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="@string/widget_day_remaining"
            android:textColor="@color/dayview_widget_text"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_day_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_day_range"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_goal"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/widget_focus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/dayview_widget_focus_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="6dp"
            android:paddingTop="3dp"
            android:paddingRight="6dp"
            android:paddingBottom="3dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/widget_focus_label"
                android:textColor="@color/dayview_widget_mint"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_focus_intention"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_preview_focus"
                android:visibility="gone" />

            <Chronometer
                android:id="@+id/widget_focus_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:textColor="@color/dayview_widget_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
