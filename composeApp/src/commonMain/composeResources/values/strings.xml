<?xml version="1.0" encoding="utf-8"?>
<!--
  Default (English) UI strings for the shared Compose screens. This is the base
  language; values-fr/strings.xml overrides it for French. Keep the two in sync
  key-for-key.
  Parameterised strings pass their values as %1$s (plain strings) so the numbers are
  never locale-grouped; a literal percent sign stays a single % (Compose Multiplatform
  substitutes %n$s placeholders but does not treat %% as an escape).
-->
